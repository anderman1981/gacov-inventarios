APP_NAME="GACOV Inventarios"
APP_ENV=local
APP_KEY=
APP_DEBUG=false  # PRODUCCIÓN: siempre false. Para desarrollo local cambia a true en tu .env
APP_URL=http://localhost:8000

APP_LOCALE=es_CO
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error  # PRODUCCIÓN: error. Para desarrollo local cambia a debug en tu .env

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gacov_inventarios
DB_USERNAME=gacov_user
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-1.5-flash,gemini-1.5-pro
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT=90
GEMINI_CONNECT_TIMEOUT=15
GEMINI_EXECUTION_TIME_LIMIT=300

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ENDPOINT=https://api.openai.com/v1/responses
OPENAI_TIMEOUT=90
OPENAI_CONNECT_TIMEOUT=15
OPENAI_EXECUTION_TIME_LIMIT=300

CHROME_DEVTOOLS_MCP_COMMAND=npx
CHROME_DEVTOOLS_MCP_PACKAGE=chrome-devtools-mcp@latest
CHROME_DEVTOOLS_MCP_ARGUMENTS=--headless,--isolated,--no-usage-statistics
CHROME_DEVTOOLS_MCP_PROTOCOL_VERSION=2025-06-18
CHROME_DEVTOOLS_MCP_STARTUP_TIMEOUT=45
CHROME_DEVTOOLS_MCP_REQUEST_TIMEOUT=30
CHROME_DEVTOOLS_MCP_CLIENT_NAME=gacov-inventarios
CHROME_DEVTOOLS_MCP_CLIENT_VERSION=1.0.0
CHROME_DEVTOOLS_MCP_REPOSITORY_URL=https://github.com/ChromeDevTools/chrome-devtools-mcp
CHROME_DEVTOOLS_MCP_REPOSITORY_BRANCH=main
CHROME_DEVTOOLS_MCP_REPOSITORY_TIMEOUT=20
CHROME_DEVTOOLS_MCP_REPOSITORY_CONNECT_TIMEOUT=10
CHROME_DEVTOOLS_MCP_KNOWLEDGE_PATH=ai/chrome-devtools-mcp

LOCAL_OCR_ENABLED=true
LOCAL_OCR_STRICT=true
LOCAL_OCR_ENDPOINT=http://127.0.0.1:8011
LOCAL_OCR_TIMEOUT=180
LOCAL_OCR_CONNECT_TIMEOUT=5
LOCAL_OCR_ALLOWED_ORIGINS=http://127.0.0.1:9119,http://localhost:9119,http://127.0.0.1:8000,http://localhost:8000
LOCAL_OCR_OLLAMA_TIMEOUT=300
LOCAL_OCR_IMAGE_MAX_SIDE=1280
LOCAL_OCR_IMAGE_QUALITY=78
OLLAMA_MODEL=llama3.2-vision:11b
SESSION_SECURE_COOKIE=true   # PRODUCCIÓN: true. Para HTTP local cambia a false en tu .env
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@gacov.com.co"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
